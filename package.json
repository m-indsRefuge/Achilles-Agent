{
    "name": "achilles-agent",
    "displayName": "Achilles Agent",
    "description": "An AI-powered development agent with long-term memory.",
    "version": "0.0.1",
    "publisher": "AchillesAI",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "AI"
    ],
    "activationEvents": [
        "onCommand:achilles.ask",
        "onCommand:achilles.clearMemory"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "achilles.ask",
                "title": "Achilles: Ask a Question"
            },
            {
                "command": "achilles.clearMemory",
                "title": "Achilles: Clear Short-term Memory"
            },
            {
                "command": "achilles.analyzeProject",
                "title": "Achilles: Analyze Project"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "achilles-view",
                    "title": "Achilles Agent",
                    "icon": "$(beaker)"
                }
            ]
        },
        "views": {
            "achilles-view": [
                {
                    "id": "achilles.sidebar",
                    "type": "webview",
                    "name": "Achilles Chat"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "dependencies": {
        "axios": "^1.4.0"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "20.x",
        "typescript": "^5.1.3",
        "eslint": "^8.41.0",
        "@typescript-eslint/eslint-plugin": "^5.59.8",
        "@typescript-eslint/parser": "^5.59.8"
    }
}
